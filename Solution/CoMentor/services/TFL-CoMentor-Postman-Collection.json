{
  "info": {
    "name": "TFL CoMentor Platform",
    "_postman_id": "tfl-comentor-001",
    "description": "Microservices API Collection for TFL CoMentor Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "membership_port", "value": "8085" },
    { "key": "skill_port", "value": "8081" },
    { "key": "evaluation_content_port", "value": "8082" },
    { "key": "assessment_port", "value": "8083" },
    { "key": "evaluation_port", "value": "8084" },
    { "key": "base_url", "value": "http://localhost" },
    { "key": "jwt_token", "value": "" }
  ],
  "item": [
    {
      "name": "Membership Service",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Patil\",\n  \"email\": \"amit@student.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{membership_port}}/api/auth/register",
              "host": ["{{base_url}}"],
              "port": "{{membership_port}}",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"amit@student.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{membership_port}}/api/auth/login",
              "host": ["{{base_url}}"],
              "port": "{{membership_port}}",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Skill Taxonomy Service",
      "item": [
        {
          "name": "Create Subject",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"C Programming\",\n  \"description\": \"Structured programming\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{skill_port}}/api/subjects",
              "host": ["{{base_url}}"],
              "port": "{{skill_port}}",
              "path": ["api", "subjects"]
            }
          }
        }
      ]
    },
    {
      "name": "Evaluation Content Service",
      "item": [
        {
          "name": "Create Question",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reverse a String\",\n  \"description\": \"Write C program to reverse string\",\n  \"questionType\": \"CODING\",\n  \"difficultyLevel\": \"Beginner\",\n  \"subjectIds\": [1],\n  \"conceptIds\": [1]\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{evaluation_content_port}}/api/questions",
              "host": ["{{base_url}}"],
              "port": "{{evaluation_content_port}}",
              "path": ["api", "questions"]
            }
          }
        }
      ]
    },
    {
      "name": "Assessment Orchestrator",
      "item": [
        {
          "name": "Create Test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"C & DS Assessment\",\n  \"totalMarks\": 100,\n  \"durationMinutes\": 60,\n  \"questionIds\": [1]\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{assessment_port}}/api/tests",
              "host": ["{{base_url}}"],
              "port": "{{assessment_port}}",
              "path": ["api", "tests"]
            }
          }
        }
      ]
    },
    {
      "name": "Evaluation Service",
      "item": [
        {
          "name": "Submit Answer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionId\": 1,\n  \"candidateId\": 101,\n  \"submittedCode\": \"#include<stdio.h>...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}:{{evaluation_port}}/api/assessments/1/submit",
              "host": ["{{base_url}}"],
              "port": "{{evaluation_port}}",
              "path": ["api", "assessments", "1", "submit"]
            }
          }
        }
      ]
    }
  ]
}